rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && data.ownerUid == request.auth.uid;
    }

    function userHouseholdId() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.householdId : null;
    }

    function taskHouseholdMatch() {
      return isSignedIn() &&
        resource.data.keys().hasAny(['householdId']) &&
        resource.data.householdId != null &&
        resource.data.householdId == userHouseholdId();
    }

    function projectHouseholdMatch() {
      return isSignedIn() &&
        resource.data.keys().hasAny(['householdId']) &&
        resource.data.householdId != null &&
        resource.data.householdId == userHouseholdId();
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function authBootstrapComplete() {
      return exists(/databases/$(database)/documents/bootstrap/auth);
    }

    match /bootstrap/auth {
      allow get: if true;
      allow list: if false;
      allow create: if isSignedIn() &&
        !authBootstrapComplete() &&
        request.resource.data.keys().hasOnly(["adminUid", "createdAt"]) &&
        request.resource.data.adminUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /admins/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if isSignedIn() &&
        request.auth.uid == uid &&
        !authBootstrapComplete() &&
        request.resource.data.keys().hasOnly(["email", "createdAt"]);
      allow update, delete: if false;
    }

    match /inviteCodes/{code} {
      allow get: if (
          resource.data.used == false &&
          (!resource.data.keys().hasAny(["expiresAt"]) || resource.data.expiresAt > request.time)
        ) || isAdmin();
      allow list: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if (
          isSignedIn() &&
          resource.data.used == false &&
          request.resource.data.code == resource.data.code &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.expiresAt == resource.data.expiresAt &&
          request.resource.data.used == true &&
          request.resource.data.usedBy == request.auth.uid &&
          request.resource.data.usedAt == request.time
        ) || isAdmin();
    }

    match /users/{uid} {
      allow get: if isSignedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /households/{householdId} {
      allow get: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      allow list: if false;
      allow create: if isSignedIn() &&
        request.auth.uid in request.resource.data.memberUids;
      allow update: if isSignedIn() && request.auth.uid in resource.data.memberUids;
      allow delete: if false;
    }

    match /tasks/{taskId} {
      allow create: if isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.auth.uid in request.resource.data.assigneeUids &&
        request.resource.data.assigneeUids.size() >= 1 &&
        request.resource.data.householdId == userHouseholdId();
      allow read: if isSignedIn() && (
        isOwner(resource.data) ||
        taskHouseholdMatch()
      );
      allow update, delete: if isSignedIn() && (
        isOwner(resource.data) ||
        taskHouseholdMatch()
      );
    }

    match /projects/{projectId} {
      allow create: if isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        request.resource.data.ownerUid == request.auth.uid &&
        request.auth.uid in request.resource.data.assigneeUids &&
        request.resource.data.assigneeUids.size() >= 1 &&
        request.resource.data.householdId == userHouseholdId();
      allow read: if isSignedIn() && (
        isOwner(resource.data) ||
        projectHouseholdMatch()
      );
      allow update, delete: if isSignedIn() && (
        isOwner(resource.data) ||
        projectHouseholdMatch()
      );
    }

    match /activityLog/{entryId} {
      allow create: if isOwner(request.resource.data);
      allow read, update, delete: if isOwner(resource.data);
    }

    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /calendarMirrorEvents/{eventId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /calendarMirrorFeedMeta/{docId} {
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow read, update, delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
